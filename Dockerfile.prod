# Dockerfile.prod
# Production image — src/ baked in, gzip on, aggressive cache headers.
# Build:   docker build -f Dockerfile.prod -t urwort:latest .
# Run:     docker run -p 8080:8080 urwort:latest

# syntax=docker/dockerfile:1
FROM nginx:alpine

RUN rm -rf /usr/share/nginx/html/*

# Copy app source into image
COPY src/ /usr/share/nginx/html/

COPY nginx.prod.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
