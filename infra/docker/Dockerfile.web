# infra/docker/Dockerfile.web
# Development web image — nginx:alpine serving src/ via volume mount.
# Files are NOT copied into the image; they are mounted at runtime.
# Rebuild only needed if nginx.dev.conf changes.

# syntax=docker/dockerfile:1
FROM nginx:alpine

RUN rm -rf /usr/share/nginx/html/*

# Build context is project root (../../ relative to this file)
COPY infra/docker/nginx.dev.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
