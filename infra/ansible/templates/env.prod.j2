# urwort production environment — generated by Ansible
# Located at /opt/urwort/.env on the server

# ── Domain ─────────────────────────────────────────────────────────────────────
# sslip.io resolves <ip-with-dashes>.sslip.io → the server IP automatically
URWORT_DOMAIN={{ server_ip | replace('.', '-') }}.sslip.io

# ── API ─────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────────────────────────
# SQLite DB is stored on the persistent Hetzner volume.
# DATA_DIR is used by docker-compose.prod.yml to mount the volume.
DATA_DIR={{ volume_mount }}
DB_PATH=/app/data/urwort.db

# ── DWDS enrichment ─────────────────────────────────────────────────────────────
DWDS_RATE_LIMIT=30

# ── S3 / Object Storage — disabled for urwort ───────────────────────────────────
# Uncomment if you add bucket storage later.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=https://nbg1.your-objectstorage.com
# AWS_DEFAULT_REGION=nbg1

# ── RunPod — disabled for urwort ────────────────────────────────────────────────
# urwort has no GPU worker pipeline.
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=

# ── LLM — disabled for urwort ───────────────────────────────────────────────────
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
