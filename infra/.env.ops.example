# ============================================================
# urwort Ops — Environment Variables
# Copy to .env.ops and fill in your values:
#   cp infra/.env.ops.example infra/.env.ops
#
# Single source of truth for all credentials.
# TF_VAR_* are derived automatically by entrypoint.sh — never duplicate here.
#
# NEVER commit .env.ops to git — it is in .gitignore
# ============================================================

# ── Hetzner Cloud ─────────────────────────────────────────────
HCLOUD_TOKEN=

# ── S3 / Object Storage — disabled for urwort ────────────────
# Uncomment if you add bucket storage later.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=https://nbg1.your-objectstorage.com
# AWS_DEFAULT_REGION=nbg1

# ── RunPod — disabled for urwort ─────────────────────────────
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=

# ── LLM — disabled for urwort ────────────────────────────────
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# ── GitHub Container Registry — disabled for urwort ──────────
# urwort builds images directly on the server; no GHCR needed.
# GITHUB_USER=
# GH_PAT_TOKEN=
