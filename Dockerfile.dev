# ============================================================
# Urwort — Phase 1A Development Container (GPU-enabled)
# ============================================================
# CUDA 12.6 + Node.js 22 + Python 3 in a single container.
# GPU passthrough for compute-layout.py (UMAP, force-directed).
#
# Usage:
#   ./dev.sh             # start + open shell
#   ./deploy.sh          # export + build + deploy
# ============================================================

FROM nvidia/cuda:12.6.3-runtime-ubuntu22.04

# Avoid interactive prompts during apt install
ENV DEBIAN_FRONTEND=noninteractive

# ---- System packages: Node.js 22, Python 3, SQLite, git ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    gnupg \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    sqlite3 \
    git \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (latest LTS — currently 24.x)
RUN curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Create Python venv so pip installs don't conflict with system
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# ---- Create 'node' user (UID 1000) matching typical host UID ----
RUN groupadd -g 1000 node && \
    useradd -u 1000 -g node -m -s /bin/bash node && \
    chown -R node:node /opt/venv

WORKDIR /workspace

# ---- Python dependencies (API) ----
COPY api/requirements.txt /tmp/api-requirements.txt
RUN pip install --no-cache-dir -r /tmp/api-requirements.txt

# ---- Python dependencies (Phase 1A: layout computation) ----
RUN pip install --no-cache-dir \
    gensim>=4.3.0 \
    umap-learn>=0.5.0 \
    numpy>=1.24.0 \
    scipy>=1.10.0 \
    cupy-cuda12x

# ---- Node dependencies (Game) ----
COPY game/package.json game/package-lock.json* /tmp/game/
RUN cd /tmp/game && npm install && mkdir -p /workspace/game && \
    cp -r node_modules /workspace/game/ && \
    chown -R node:node /workspace

# ---- Nice bash prompt + colors for the dev shell ----
RUN echo '\n\
# ── Urwort dev shell (GPU) ──────────────────────────────────\n\
export TERM=xterm-256color\n\
alias ls="ls --color=auto"\n\
alias ll="ls -lah --color=auto"\n\
alias grep="grep --color=auto"\n\
parse_git_branch() { git branch 2>/dev/null | sed -n "s/* \\(.*\\)/ (\\1)/p"; }\n\
PS1="\\[\\033[0;35m\\][urwort-gpu]\\[\\033[0m\\] \\[\\033[1;34m\\]\\w\\[\\033[0;33m\\]\\$(parse_git_branch)\\[\\033[0m\\] \\$ "\n\
alias export-ontology="cd /workspace && python3 tools/export-ontology.py"\n\
alias compute-layout="cd /workspace && python3 tools/compute-layout.py"\n\
alias build="cd /workspace/game && npm run build"\n\
alias dev="cd /workspace/game && npm run dev"\n\
' >> /home/node/.bashrc

# Expose ports: Vite dev server + FastAPI
EXPOSE 5173 8000

# Switch to non-root user
USER node

# Default command — start Vite dev server
CMD ["bash", "-c", "cd /workspace/game && npm install && npm run dev"]
